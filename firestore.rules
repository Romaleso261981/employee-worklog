rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isBilousMirrorSource() {
      return isAuth() &&
        request.auth.token.email != null &&
        request.auth.token.email.lower() == 'bilous@gmail.com';
    }

    function isMirrorTargetEmail(email) {
      return email.lower() == 'stratichuk@gmail.com' ||
        email.lower() == 'stratiichuk@gmail.com';
    }

    match /users/{userId} {
      allow read: if isAuth() && (
        request.auth.uid == userId ||
        (isBilousMirrorSource() && isMirrorTargetEmail(resource.data.email))
      );
      allow create: if isAuth() && request.auth.uid == userId;
      allow update: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    match /workEntries/{workId} {
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );

      allow create: if isAuth() && (
        request.resource.data.userId == request.auth.uid ||
        (
          isBilousMirrorSource() &&
          isMirrorTargetEmail(request.resource.data.userEmail)
        )
      );

      // Працівник може редагувати лише свої записи та не змінюючи
      // userId / userEmail / amount (фінансові/власницькі поля).
      allow update: if isAdmin() || (
        isAuth() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.userEmail == resource.data.userEmail &&
        request.resource.data.amount == resource.data.amount &&
        request.resource.data.paymentStatus == resource.data.paymentStatus &&
        request.resource.data.organizationAmount == resource.data.organizationAmount &&
        request.resource.data.organizationPaid == resource.data.organizationPaid
      );
      allow delete: if isAdmin() || (
        isAuth() && resource.data.userId == request.auth.uid
      );
    }

    match /salaryPayouts/{payoutId} {
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );

      allow create: if isAdmin() || (
        isAuth() &&
        request.resource.data.userId == request.auth.uid
      );
      allow update, delete: if isAdmin();
    }
  }
}
